# Aotearoa Voice — environment variables
# Copy to .env and fill in. Do NOT commit .env.

# === Anthropic (agent layer) ===
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Model used for the agent loop. Sonnet is the right tradeoff for this demo
# (latency + cost). Override if you want to test Opus or Haiku.
ANTHROPIC_MODEL=claude-sonnet-4-6

# === OpenAI Whisper (STT) ===
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
WHISPER_MODEL=whisper-1

# === ElevenLabs (TTS) ===
ELEVENLABS_API_KEY=sk_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Jamie's cloned voice ID (see the README on why this voice is chosen)
ELEVENLABS_VOICE_ID=replace-with-your-voice-id
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
# Voice tuning — see ElevenLabs docs. Defaults are tuned for narrative warmth.
ELEVENLABS_STABILITY=0.5
ELEVENLABS_SIMILARITY_BOOST=0.75
ELEVENLABS_STYLE=0.2

# === ElevenLabs pronunciation dictionary (optional) ===
# Improves Te Reo Māori place-name pronunciation. Run
# `scripts/setup_pronunciation_dict.py` once to upload the dictionary, then
# paste the printed IDs below. Both must be set for the dictionary to take
# effect. Leave blank to use the model's default pronunciation. Requires the
# 'Pronunciation Dictionaries: Write' scope on your ElevenLabs key for setup.
# ELEVENLABS_PRONUNCIATION_DICTIONARY_ID=
# ELEVENLABS_PRONUNCIATION_DICTIONARY_VERSION_ID=

# === MCP server ===
# How the backend reaches the MCP server inside Docker. Override if you run
# the MCP server outside compose.
MCP_SERVER_URL=http://mcp_server:8001/sse

# DNS-rebinding allow-list for the MCP server's Host-header check. The default
# already covers localhost + the docker-compose service name. Add public
# hostnames here if you expose the MCP server through Cloudflare Tunnel or
# Cloud Run, e.g. "mcp.aotearoa.example.com".
# MCP_ALLOWED_HOSTS=localhost,localhost:8001,127.0.0.1,127.0.0.1:8001,mcp_server,mcp_server:8001

# === Cloudflare Tunnel (optional — only set for public demo deploy) ===
# Token from Cloudflare Zero Trust → Networks → Tunnels → Create a tunnel.
# When set, `docker compose --profile tunnel up` brings up the cloudflared
# sidecar alongside the rest of the stack. Leave blank for local-only dev.
# CLOUDFLARE_TUNNEL_TOKEN=eyJhIjoi...

# Frontend's public API URL — baked into the build at compile time.
# For local dev: http://localhost:8002 (the default in docker-compose.yml).
# For the tunneled public demo: https://api.aotearoa.<your-domain>
# FRONTEND_API_BASE_URL=https://api.aotearoa.example.com

# === CORS ===
# Comma-separated list of frontend origins allowed to call the backend.
# In dev, include http://localhost:5173. For the public demo, add your
# tunneled frontend hostname (e.g. https://aotearoa.<your-domain>).
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# === Rate limiting ===
# Per-IP token bucket for the chat endpoint. Generous for a demo, tight enough
# to discourage abuse if the URL gets shared.
RATE_LIMIT_PER_MINUTE=20

# === Logging ===
LOG_LEVEL=INFO
